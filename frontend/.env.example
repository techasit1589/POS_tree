# คัดลอกเป็น .env แล้วใส่ค่าจริง
# Vercel: ตั้งใน Project Settings → Environment Variables

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# PIN สำหรับล็อกหน้าแอป (6 หลัก)
APP_PIN=xxxxxx

# Secret สำหรับ sign cookie — ใส่ random string ยาวๆ อย่างน้อย 32 ตัวอักษร
# สร้างได้ด้วย: openssl rand -base64 32
COOKIE_SECRET=replace-with-a-long-random-string
